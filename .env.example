# Public site origin used by Canonical, OpenGraph, JSON-LD, Sitemap, robots, and RSS.
# Current production (until the approved domain activation): https://judao.club
# Domain activation target: https://xintuozhiwuye.com
# Local development: http://localhost:3000
# Vercel Preview may leave this unset to use VERCEL_URL automatically.
NEXT_PUBLIC_SITE_URL=https://judao.club

# Required for production builds and runtime. Use secret environment variables in Vercel.
# Do not commit real credentials.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Closed by default. Enable only when the writable runtime/storage design is approved.
KNOWLEDGE_WRITES_ENABLED=false

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
