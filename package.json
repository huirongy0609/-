{
  "name": "community-governance-map-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "studio": "remotion studio remotion/index.ts",
    "render:sample": "remotion render remotion/index.ts BookGuideVideo out/book-guide-sample.mp4 --props=data/sample-script.json",
    "geo:generate-keywords": "node scripts/generate-keywords.mjs",
    "geo:generate-pages": "node scripts/generate-pages.mjs",
    "geo:refresh-sitemap": "node scripts/refresh-sitemap.mjs",
    "geo:update-publish-log": "node scripts/update-publish-log.mjs",
    "geo:generate": "node scripts/generate-geo-mvp.mjs",
    "geo:asset-listen": "node scripts/geo-asset-listener.mjs",
    "geo:build-site": "node scripts/build-site.mjs",
    "geo:stability-check": "node scripts/geo-stability-check.mjs",
    "foundation:index": "node scripts/generate-foundation-index.mjs",
    "foundation:validate": "node scripts/validate-foundation.mjs --write-report",
    "foundation:sync": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/foundation-engine.ts sync",
    "foundation:engine:validate": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/foundation-engine.ts validate",
    "foundation:test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test tests/foundation-engine.test.ts",
    "beta:test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test tests/website-framework.test.ts tests/website-beta.test.ts",
    "foundation:refresh": "npm run foundation:index && npm run foundation:sync && npm run foundation:validate && npm run foundation:engine:validate"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.448",
    "@remotion/cli": "^4.0.448",
    "@remotion/player": "^4.0.448",
    "@remotion/renderer": "^4.0.448",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.468.0",
    "next": "^14.2.23",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.448",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.17.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitepress": "^1.6.4"
  }
}
